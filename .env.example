# Backend
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5199

# MySQL / MariaDB
# Use either DATABASE_URL or the separate DB_* values below.
# DATABASE_URL=mysql://user:password@localhost:3306/turnit_phase1
DB_HOST=localhost
DB_PORT=3306
DB_NAME=turnit_phase1
DB_USER=root
DB_PASSWORD=

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_ORDER=20
STAFF_MAX_ACTIVE_ORDERS=3

# Frontend
VITE_API_URL=http://localhost:5000/api
